<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="Ui.Dark" Color="WhiteSmoke" />
    <SolidColorBrush x:Key="Ui.ToolbarHover" Color="#D8D8D8" />
    <SolidColorBrush x:Key="Ui.Light" Color="WhiteSmoke" />
    <SolidColorBrush x:Key="Ui.Light2" Color="#f2f2f2" />
    <SolidColorBrush x:Key="Ui.ContrastLight" Color="#C0C0C0" />
    <SolidColorBrush x:Key="Ui.UltraLight2" Color="AliceBlue" />
    <SolidColorBrush x:Key="Ui.Ultralight" Color="AliceBlue" />
    <SolidColorBrush x:Key="Ui.Arrow" Color="#252525" />
    <SolidColorBrush x:Key="Ui.ListBoxSelect" Color="#D8D8D8" />
    <SolidColorBrush x:Key="Ui.Background" Color="White" />
    <SolidColorBrush x:Key="Ui.BackgroundLight" Color="White" />
    <SolidColorBrush x:Key="Ui.BackgroundDark" Color="Black" />


    <SolidColorBrush x:Key="Ui.Blue" Color="#00579f" />
    <SolidColorBrush x:Key="Ui.BlueBright" Color="#006cc5" />

    <!-- StatusBar -->
    <Style TargetType="StatusBar">
        <Setter Property="Background" Value="{DynamicResource Ui.Light}" />
    </Style>

    <!-- TextBlock -->
    <Style x:Key="BaseTextBlockStyle" TargetType="TextBlock">
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- Glyph -->
    <SolidColorBrush x:Key="ButtonGlyphBrush" Color="#444"/>

    <!-- Bpress Tokens (Light) -->
    <SolidColorBrush x:Key="Bpress.Text.Primary" Color="#121212" />
    <SolidColorBrush x:Key="Bpress.Text.Secondary" Color="#666666" />
    <SolidColorBrush x:Key="Bpress.Background.Main" Color="#FFFFFF" />
    <SolidColorBrush x:Key="Bpress.Background.Card" Color="#F5F5F7" />
    <SolidColorBrush x:Key="Bpress.Background.Card.Hover" Color="#FFFFFF" />
    <Color x:Key="Bpress.Color.Border.Card">#E0E0E0</Color>

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="Controls/ToolbarLight.xaml" />
        <ResourceDictionary Source="Controls/ContextMenuLight.xaml" />
        <ResourceDictionary Source="Controls/ProgressBarBoth.xaml" />
    </ResourceDictionary.MergedDictionaries>

</ResourceDictionary>