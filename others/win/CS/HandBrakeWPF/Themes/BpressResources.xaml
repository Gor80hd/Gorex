<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib"
                    xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework">

    <!-- BPRESS Premium Design System -->
    
    <!-- Shared Tokens -->
    <CornerRadius x:Key="Bpress.CornerRadius.ExtraLarge">20</CornerRadius>
    <CornerRadius x:Key="Bpress.CornerRadius.Large">14</CornerRadius>
    <sys:Double x:Key="Bpress.Opacity.Secondary">0.6</sys:Double>

    <!-- Brushes -->
    <SolidColorBrush x:Key="Bpress.Accent" Color="#007ACC" />

    <!-- Dashed Border Style for Drag & Drop -->
    <Style x:Key="Bpress.DashedArea" TargetType="ContentControl">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="{DynamicResource Bpress.Text.Secondary}" />
        <Setter Property="BorderThickness" Value="2" />
        <Setter Property="Opacity" Value="0.4" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ContentControl">
                    <Grid>
                        <Rectangle x:Name="DashedRect" 
                                   Stroke="{DynamicResource Bpress.Text.Secondary}" 
                                   StrokeThickness="{TemplateBinding BorderThickness}" 
                                   StrokeDashArray="6 4"
                                   RadiusX="20" RadiusY="20"
                                   Fill="{TemplateBinding Background}"/>
                        <ContentPresenter Margin="{TemplateBinding Padding}"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <!-- Hover Animations -->
                        <EventTrigger RoutedEvent="MouseEnter">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0.7" Duration="0:0:0.3" />
                                    <DoubleAnimation Storyboard.TargetName="DashedRect" Storyboard.TargetProperty="StrokeThickness" To="2.5" Duration="0:0:0.3" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <EventTrigger RoutedEvent="MouseLeave">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0.4" Duration="0:0:0.3" />
                                    <DoubleAnimation Storyboard.TargetName="DashedRect" Storyboard.TargetProperty="StrokeThickness" To="2" Duration="0:0:0.3" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        
                        <!-- Drag & Drop Animations -->
                        <EventTrigger RoutedEvent="DragEnter">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0.8" Duration="0:0:0.2" />
                                    <DoubleAnimation Storyboard.TargetName="DashedRect" Storyboard.TargetProperty="StrokeThickness" To="3" Duration="0:0:0.2" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <EventTrigger RoutedEvent="DragLeave">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0.4" Duration="0:0:0.3" />
                                    <DoubleAnimation Storyboard.TargetName="DashedRect" Storyboard.TargetProperty="StrokeThickness" To="2" Duration="0:0:0.3" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <EventTrigger RoutedEvent="Drop">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0.4" Duration="0:0:0.3" />
                                    <DoubleAnimation Storyboard.TargetName="DashedRect" Storyboard.TargetProperty="StrokeThickness" To="2" Duration="0:0:0.3" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Premium Nav Link Style -->
    <Style x:Key="Bpress.NavLink" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource Bpress.Text.Secondary}" />
        <Setter Property="Padding" Value="16,8" />
        <Setter Property="Margin" Value="0,0,12,0" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <ContentPresenter x:Name="CP" ContentSource="Content" Opacity="0.6" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="CP" Property="Opacity" Value="1.0" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

