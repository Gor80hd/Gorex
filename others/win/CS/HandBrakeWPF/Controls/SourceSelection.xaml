<UserControl x:Class="HandBrakeWPF.Controls.SourceSelection"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:HandBrakeWPF.Controls"
             xmlns:Properties="clr-namespace:HandBrakeWPF.Properties"
             xmlns:converters="clr-namespace:HandBrakeWPF.Converters"
             xmlns:themes="clr-namespace:HandBrakeWPF.Themes"
             x:Name="sourcePanel">

    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:ThemeImageConverter x:Key="themeConverter" />
    </UserControl.Resources>

    <Grid Background="{DynamicResource Bpress.Background.Main}">
        <Grid.RowDefinitions>
            <RowDefinition Height="60" /> <!-- Top Bar -->
            <RowDefinition Height="*" />    <!-- Main Content -->
        </Grid.RowDefinitions>

        <!-- Navigation Bar -->
        <Grid Grid.Row="0" Margin="16,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" WindowChrome.IsHitTestVisibleInChrome="True">
                <Button Content="Открыть" Style="{DynamicResource Bpress.NavLink}" Command="{Binding RelayCommand}" CommandParameter="FileScan" Margin="0,0,8,0" />
                <Button Content="Настройки" Style="{DynamicResource Bpress.NavLink}" Command="{Binding RelayCommand}" CommandParameter="OpenOptionsWindow" Margin="0,0,8,0" />
                <Button Content="О программе" Style="{DynamicResource Bpress.NavLink}" Command="{Binding RelayCommand}" CommandParameter="OpenAboutApplication" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" WindowChrome.IsHitTestVisibleInChrome="True">
                <!-- Theme Toggle -->
                <CheckBox IsChecked="{Binding IsDarkMode}" Style="{DynamicResource Bpress.ThemeToggle}" VerticalAlignment="Center" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" Margin="20,0,20,20">
            <ContentControl Style="{DynamicResource Bpress.DashedArea}" Padding="40">
                <Grid>
                    <!-- Center Content -->
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <!-- Upload Icon (Simplified Path) -->
                        <Viewbox Width="80" Height="80" Margin="0,0,0,20" Opacity="0.4">
                            <Canvas Width="24" Height="24">
                                <Path Fill="{DynamicResource Bpress.Text.Primary}" Data="M14,13V17H10V13H7L12,8L17,13M19.35,10.03C18.67,6.59 15.64,4 12,4C9.11,4 6.6,5.64 5.35,8.03C2.34,8.36 0,10.9 0,14A6,6 0 0,0 6,20H19A5,5 0 0,0 24,15C24,12.36 21.95,10.22 19.35,10.03Z" />
                            </Canvas>
                        </Viewbox>
                        
                        <TextBlock Text="Add file / files" FontSize="14" FontWeight="Medium" Foreground="{DynamicResource Bpress.Text.Primary}" Opacity="0.5" HorizontalAlignment="Center" />
                    </StackPanel>

                    <!-- Bottom Helper Text (Aligned inside the dashed area but at the bottom) -->
                    <TextBlock Text="Вы можете выбрать один или несколько файлов для конвертации, просто перенесите их в эту область" 
                               FontSize="12" Foreground="{DynamicResource Bpress.Text.Secondary}" Opacity="0.6" 
                               HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,40"
                               TextAlignment="Center" MaxWidth="400" TextWrapping="Wrap"/>
                </Grid>
            </ContentControl>
        </Grid>
    </Grid>
</UserControl>
