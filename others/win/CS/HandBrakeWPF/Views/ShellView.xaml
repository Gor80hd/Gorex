<Window x:Class="HandBrakeWPF.Views.ShellView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:Data="clr-namespace:System.Windows.Data;assembly=PresentationFramework"
        xmlns:Converters="clr-namespace:HandBrakeWPF.Converters"
        xmlns:views="clr-namespace:HandBrakeWPF.Views"
        xmlns:Controls="clr-namespace:HandBrakeWPF.Controls"
        xmlns:Properties="clr-namespace:HandBrakeWPF.Properties"
        Title="{Binding MainViewModel.WindowTitle, ElementName=shellView}"
        Width="1060"
        Height="690"
        MinWidth="1018"
        MinHeight="690"
        AllowDrop="True"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True"
        WindowStartupLocation="CenterScreen"
        TextOptions.TextFormattingMode="Display"
        Drop="ShellView_OnDrop"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Name="shellView">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="60" 
                      CornerRadius="20"
                      GlassFrameThickness="0" 
                      ResizeBorderThickness="8" />
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <Converters:BooleanToVisibilityConverter x:Key="boolToVisConverter" />
    </Window.Resources>

    <Grid Background="{DynamicResource Bpress.Background.Main}">
        <Grid.RowDefinitions>
            <RowDefinition Height="60" /> <!-- Custom Title Bar -->
            <RowDefinition Height="*" />    <!-- Content Area -->
        </Grid.RowDefinitions>

        <!-- Global Title Bar -->
        <Grid Grid.Row="0" Margin="16,0">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Viewbox Height="24" Margin="0,0,24,0" VerticalAlignment="Center">
                    <Canvas Width="1024" Height="1024">
                        <Path Fill="{DynamicResource Bpress.Text.Primary}" Data="M475.415 46.7394C478.505 45.9272 486.557 45.9726 489.918 46.0244C609.607 47.8756 717.391 120.168 760.512 232.981C786.016 299.702 787.259 375.466 759.113 441.475L598.146 441.421C611.585 423.413 622.191 406.871 628.58 385.229C639.765 347.34 637.856 305.148 618.623 270.177C599.182 234.828 568.83 207.222 529.971 195.642C491.259 184.17 449.579 188.657 414.178 208.11C378.498 227.926 356.39 260.249 345.271 299.134C326.419 370.373 360.684 439.52 425.564 472.413C443.813 481.665 462.458 485.605 482.573 488.188C444.692 527.356 405.165 564.723 367.56 603.586C345.913 595.957 315.667 575.387 298.429 560.459C239.877 510.287 203.692 438.79 197.885 361.795C191.975 281.297 215.668 207.388 268.827 146.216C324.456 82.203 392.411 52.6925 475.415 46.7394Z" />
                        <Path Fill="{DynamicResource Bpress.Text.Primary}" Data="M599.728 481.69C657.856 483.212 708.463 503.811 750.261 544.665C798.357 591.367 825.948 655.23 826.973 722.238C827.963 789.499 801.884 854.339 754.591 902.21C723.506 933.423 679.819 961.053 636.743 971.226C598.892 980.168 544.519 977.283 504.135 977.272L347.154 977.229C347.549 947.524 346.632 916.201 346.656 886.173L347.627 760.348C347.577 730.162 342.604 669.901 368.332 669.901C374.658 664.673 382.145 661.034 390.168 659.291C401.907 656.775 467.572 658.129 480.382 659.512L480.576 835.474C513.86 834.534 548.091 836.958 581.133 835.31C634.982 832.627 679.388 782.817 680.998 730.216C681.988 700.108 671.007 670.83 650.457 648.788C637.412 635.097 620.91 625.18 602.693 620.082C581.639 614.233 546.343 615.305 523.24 615.02C487.183 614.819 451.126 614.405 415.073 613.773C434.396 593.116 456.392 572.269 475.96 552.088C517.855 508.882 535.165 485.246 599.728 481.69Z" />
                    </Canvas>
                </Viewbox>
                
                <!-- Navigation Links -->
                <StackPanel Orientation="Horizontal" WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Content="Открыть" Style="{DynamicResource Bpress.NavLink}" Command="{Binding RelayCommand}" CommandParameter="FileScan" />
                    <Button Content="Настройки" Style="{DynamicResource Bpress.NavLink}" Command="{Binding RelayCommand}" CommandParameter="OpenOptionsWindow" />
                    <Button Content="О программе" Style="{DynamicResource Bpress.NavLink}" Command="{Binding RelayCommand}" CommandParameter="OpenAboutApplication" />
                </StackPanel>
            </StackPanel>
            
            <!-- Right side: Theme Toggle and Window Controls -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" WindowChrome.IsHitTestVisibleInChrome="True">
                <CheckBox Style="{DynamicResource Bpress.ThemeToggle}" IsChecked="{Binding MainViewModel.IsDarkMode}" Margin="0,0,16,0" ToolTip="Сменить тему" />
                
                <StackPanel Orientation="Horizontal">
                    <Button Style="{DynamicResource Bpress.MacButton.Minimize}" Command="{Binding MinimizeCommand}" Content="{StaticResource Bpress.Icon.Minimize}" />
                    <Button Style="{DynamicResource Bpress.MacButton.Maximize}" Command="{Binding MaximizeCommand}" Content="{StaticResource Bpress.Icon.Maximize}" />
                    <Button Style="{DynamicResource Bpress.MacButton.Close}" Command="{Binding CloseCommand}" Content="{StaticResource Bpress.Icon.Close}" />
                </StackPanel>
            </StackPanel>
        </Grid>

        <!-- Content Area -->
        <Grid Grid.Row="1">
            <views:HybridView DataContext="{Binding MainViewModel}" 
                               Visibility="{Binding DataContext.ShowMainWindow, ElementName=shellView, Converter={StaticResource boolToVisConverter}, ConverterParameter=false}" />

            <views:OptionsView x:Name="OptionsViewModel" DataContext="{Binding OptionsViewModel}"  
                               Panel.ZIndex="0"  Visibility="{Binding DataContext.ShowOptions, ElementName=shellView, Converter={StaticResource boolToVisConverter}, ConverterParameter=false}"
                               IsEnabled="{Binding DataContext.IsMainPanelEnabled, ElementName=shellView}" />
        </Grid>

        <!-- Overlays (Status, Alerts) -->
        <Grid Grid.Row="0" Grid.RowSpan="2" DataContext="{Binding MainViewModel}" Panel.ZIndex="100">
            <!-- Status Panel -->
            <Controls:StatusPanel x:Name="loadingPanel"
                                  Visibility="{Binding ShowStatusWindow, Converter={StaticResource boolToVisConverter}, ConverterParameter=false, TargetNullValue=Collapsed, FallbackValue=Collapsed}"
                                  VerticalAlignment="Stretch" HorizontalAlignment="Stretch"
                                  Panel.ZIndex="10"
                                  IsLoading="{Binding ShowStatusWindow}"
                                  Message="{x:Static Properties:Resources.MainView_ScanningStatus}"
                                  SubMessage="{Binding StatusLabel}"
                                  ActionText="{x:Static Properties:Resources.MainView_Cancel}"
                                  SecondaryActionText="{x:Static Properties:Resources.MainView_OpenLog}"
                                  SecondaryAction="{Binding OpenLogWindowAction}"
                                  CancelAction="{Binding CancelAction}"
                                  ProgressPercentage="{Binding ProgressAmount}" />

            <!-- Alert Panel -->
            <Controls:AlertPanel x:Name="alertPanel"
                                 KeyboardNavigation.DirectionalNavigation="Contained"
                                 Visibility="{Binding ShowAlertWindow, Converter={StaticResource boolToVisConverter}, ConverterParameter=false, TargetNullValue=Collapsed, FallbackValue=Collapsed}"
                                 VerticalAlignment="Stretch" HorizontalAlignment="Stretch"
                                 Panel.ZIndex="25"
                                 Message="{Binding AlertWindowHeader}"
                                 SubMessage="{Binding AlertWindowText}"
                                 ActionText="OK"
                                 DefaultAction="{Binding AlertWindowClose}" />
        </Grid>
    </Grid>
</Window>
