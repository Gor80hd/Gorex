{
  "name": "handbrake-web-ui",
  "version": "1.0.0",
  "description": "BPRESS — HandBrake Web UI with Electron + Vite + React",
  "main": "./out/main/index.js",
  "author": "Antigravity",
  "scripts": {
    "dev": "electron-vite dev --watch",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "pack": "electron-vite build && electron-builder --dir",
    "dist": "electron-vite build && electron-builder"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "bootstrap-icons": "^1.13.1",
    "fluent-ffmpeg": "^2.1.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "electron": "^28.2.0",
    "electron-builder": "^24.9.1",
    "electron-vite": "^2.0.0",
    "sass": "^1.97.3",
    "vite": "^5.0.12"
  },
  "build": {
    "appId": "com.antigravity.bpress",
    "productName": "BPRESS",
    "win": {
      "target": "nsis",
      "extraFiles": [
        {
          "from": "../build/HandBrakeCLI.exe",
          "to": "HandBrakeCLI.exe"
        },
        {
          "from": "resources/ytdl",
          "to": "resources/ytdl"
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
