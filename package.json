{
  "name": "gorex",
  "version": "2.1.0",
  "description": "Gorex - FFmpeg / yt-dlp GUI with Electron + Vite + React",
  "main": "./out/main/index.js",
  "author": "Akhmatyarov",
  "scripts": {
    "dev": "electron-vite dev --watch",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "pack": "electron-vite build && electron-builder --dir",
    "predist": "node build/create-installer-bitmaps.js",
    "dist": "electron-vite build && electron-builder",
    "installer-assets": "node build/create-installer-bitmaps.js",
    "make-installer": "node build/make-installer.js",
    "installer:start": "cd installer && electron ."
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "@fontsource/ibm-plex-sans": "^5.2.8",
    "bootstrap-icons": "^1.13.1",
    "ffmpeg-static": "^5.3.0",
    "ffprobe-static": "^3.1.0",
    "fluent-ffmpeg": "^2.1.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "electron": "^35.7.5",
    "electron-builder": "^26.8.1",
    "electron-vite": "^3.0.1",
    "sass": "^1.97.3",
    "vite": "^6.1.7"
  },
  "build": {
    "appId": "com.akhmatyarov.gorex",
    "productName": "Gorex",
    "icon": "resources/icon.png",
    "asarUnpack": [
      "node_modules/ffmpeg-static/**",
      "node_modules/ffprobe-static/**"
    ],
    "files": [
      "out/**",
      "resources/**",
      "!installer/**",
      "!dist/**",
      "!build/**",
      "!Downloads_Temp/**",
      "!others/**"
    ],
    "win": {
      "target": "nsis",
      "extraFiles": [
        {
          "from": "resources/ytdl",
          "to": "resources/ytdl"
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
